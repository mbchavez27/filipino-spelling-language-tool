<!-- Filipino Rules -->
<rules>
    <!-- Define a new rule -->
    <rule id="VOWEL_REPETITION" name="Vowel Repetition Rule">
        <pattern>
            <token regexp="yes">^([aeiouAEIOU])\1</token>
        </pattern>
        <message>If a word starts with a vowel, only the vowel must be repeated once</message>
        <suggestion correction="aakyat">aaakyat</suggestion>
        <suggestion correction="iibig">iiibig</suggestion>
        <suggestion correction="uubo">uuubo</suggestion>
    </rule>
</rules>