<language name="Tagalog" code="tl">
    <rules>
        <category id="FILIPINO_RULES" name="Filipino Rules using MMP and OP">
            <rulegroup id="D-TO-R" name="Din/Daw to Rin/Raw Mutation">

                <rule>
                    <pattern>
                        <token regexp="yes">.*[aeiouwyAEIOUWY]<exception regexp="yes">
                            .*[rR]([ia]|aw|ay)</exception></token>
                        <token regexp="yes">d(in|aw|ito|iyan|oon)</token>
                    </pattern>
                    <message>
                        [KWF-MMP-8.1] Orthography Violation: Invalid post-vocalic 'd'. Expected 'r'
                        after a vowel or semivowel.
                    </message>
                    <suggestion>
                        <match no="2" regexp_match="^d" regexp_replace="r"></match>
                    </suggestion>

                    <example correction="raw">Malaki <marker>daw</marker></example>
                    <example correction="roon">Punta tayo <marker>doon</marker></example>
                    <example correction="riyan">Bahay <marker>diyan</marker></example>
                    <example correction="rin">Gagawin ko <marker>din</marker></example>

                    <example>Maaari din</example>
                    <example>Araw-araw daw</example>
                    <example>Sari-sari dito</example>
                    <example>Kutsara diyan</example>
                </rule>

                <rule>
                    <pattern>
                        <token regexp="yes">.*[aeiouwyAEIOUWY]<exception regexp="yes">
                            .*[rR]([ia]|aw|ay)</exception></token>
                        <token regexp="yes">D(in|aw|ito|iyan|oon)</token>
                    </pattern>
                    <message>
                        [KWF-MMP-8.1] Orthography Violation: Invalid post-vocalic 'D'. Expected 'R'
                        after a vowel or semivowel.
                    </message>
                    <suggestion>
                        <match no="2" regexp_match="^D" regexp_replace="R"></match>
                    </suggestion>

                    <example correction="Raw">Malaki <marker>Daw</marker></example>
                    <example correction="Roon">Punta tayo <marker>Doon</marker></example>
                    <example correction="Riyan">Bahay <marker>Diyan</marker></example>
                    <example correction="Rin">Gagawin ko <marker>Din</marker></example>

                    <example>Maaari Din</example>
                    <example>Araw-araw Daw</example>
                    <example>Sari-sari Dito</example>
                    <example>Kutsara Diyan</example>
                </rule>

            </rulegroup>
        </category>
    </rules>
</language>