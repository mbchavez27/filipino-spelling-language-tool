<?xml version="1.0" encoding="UTF-8"?>
<rules lang="tl" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../rules.xsd">

    <category id="FILIPINO_RULES" name="Filipino Rules (KWF Standards)">
        
        <rulegroup id="D_TO_R" name="Din/Daw to Rin/Raw Mutation">
            <rule>
                <pattern>
                    <token regexp="yes">.*[aeiouwyAEIOUWY]<exception regexp="yes">.*[rR]([ia]|aw|ay)</exception></token>
                    <marker>
                        <token regexp="yes">d(in|aw|ito|iyan|oon)</token>
                    </marker>
                </pattern>
                <message>Gamitin ang 'r' sa halip na 'd' pagkatapos ng patinig o semivowel. Dapat ay: <suggestion><match no="2" regexp_match="^d" regexp_replace="r"/></suggestion></message>
                <short>[KWF-MMP-8.1] Maling D/R (Small Letter)</short>
                <example correction="raw">Malaki <marker>daw</marker></example>
                <example>Maaari din</example>
            </rule>
            <rule>
                <pattern>
                    <token regexp="yes">.*[aeiouwyAEIOUWY]<exception regexp="yes">.*[rR]([ia]|aw|ay)</exception></token>
                    <marker>
                        <token regexp="yes">D(in|aw|ito|iyan|oon)</token>
                    </marker>
                </pattern>
                <message>Gamitin ang 'R' sa halip na 'D' pagkatapos ng patinig o semivowel. Dapat ay: <suggestion><match no="2" regexp_match="^D" regexp_replace="R"/></suggestion></message>
                <short>[KWF-MMP-8.1] Maling D/R (Capital Letter)</short>
                <example correction="Raw">Malaki <marker>Daw</marker></example>
                <example>Maaari Din</example>
            </rule>
        </rulegroup>

        <rulegroup id="O_TO_U_REDUPLICATION" name="O to U Hyphenation Error">
            <rule>
                <pattern>
                    <token regexp="yes">(an|sin|pis|pit)u</token>
                    <token>-</token>
                    <token regexp="yes">(ano|sino|piso|pito)</token>
                </pattern>
                <message>Ang 'o' ay hindi dapat palitan ng 'u' kapag inuulit ang salitang-ugat. Dapat ay: <suggestion><match no="1" regexp_match="u$" regexp_replace="o"/>-<match no="3"/></suggestion></message>
                <short>[KWF-MMP-7.5] Maling O-to-U</short>
                <example correction="ano-ano">Sila ay <marker>anu-ano</marker></example>
                <example>Ang mga ano-ano.</example>
            </rule>
            <rule>
                <pattern>
                    <token regexp="yes">taun</token>
                    <token>-</token>
                    <token regexp="yes">taon</token>
                </pattern>
                <message>Dapat ay: <suggestion>taon-taon</suggestion></message>
                <short>[KWF-MMP-7.5] Maling O-to-U</short>
                <example correction="taon-taon">Ito ay ginagawa <marker>taun-taon</marker></example>
                <example>Ito ay ginagawa taon-taon.</example>
            </rule>
        </rulegroup>

        <rulegroup id="IKA_AT_ALAS_NUMERO" name="Ika/Alas at Numero Hyphenation">
            <rule>
                <pattern>
                    <token regexp="yes">ika([0-9]+)</token>
                </pattern>
                <message>Kailangan ng gitling kapag ikinakabit ang unlaping 'ika-' sa numero. Dapat ay: <suggestion><match no="1" regexp_match="ika([0-9]+)" regexp_replace="ika-$1"/></suggestion></message>
                <short>[KWF-MMP-11.8] Kulang sa Gitling</short>
                <example correction="ika-10">Siya ay nasa <marker>ika10</marker> baitang.</example>
                <example>Nasa ika-10 baitang na siya.</example>
            </rule>
            <rule>
                <pattern>
                    <token regexp="yes">alas([0-9]+)</token>
                </pattern>
                <message>Kailangan ng gitling kapag ikinakabit ang 'alas-' sa numero na tumutukoy sa oras. Dapat ay: <suggestion><match no="1" regexp_match="alas([0-9]+)" regexp_replace="alas-$1"/></suggestion></message>
                <short>[KWF-MMP-11.8] Kulang sa Gitling</short>
                <example correction="alas-12">Magkikita tayo mamayang <marker>alas12</marker> ng tanghali.</example>
                <example>Magkikita tayo mamayang alas-12 ng tanghali.</example>
            </rule>
            <rule>
                <pattern>
                    <token regexp="yes">ala([0-9]+)</token>
                </pattern>
                <message>Kailangan ng gitling kapag ikinakabit ang 'ala-' sa numero na tumutukoy sa oras. Dapat ay: <suggestion><match no="1" regexp_match="ala([0-9]+)" regexp_replace="ala-$1"/></suggestion></message>
                <short>[KWF-MMP-11.8] Kulang sa Gitling</short>
                <example correction="ala-1">Uuwi siya ng <marker>ala1</marker> ng hapon.</example>
                <example>Uuwi siya ng ala-1 ng hapon.</example>
            </rule>
        </rulegroup>

    </category>
</rules>